# Copy this file to .env.web.local and fill in private values locally.
# Do not commit real secrets. Use neutral placeholders here only.

# Local schema setup should use Supabase Session pooler when Direct connection is unreachable.
# Get this from Supabase Dashboard -> Connect -> Session pooler.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
APP_URL="http://localhost:3000"
DATABASE_POOL_MAX="5"
# TLS to Supabase Postgres is verified by default. Only set this to "true" if a
# non-standard setup requires skipping certificate verification (not recommended).
# DATABASE_SSL_NO_VERIFY="false"
HEALTH_DEBUG="false"
# Detailed health output also requires this secret sent as the x-health-token header.
HEALTH_DEBUG_TOKEN=""
# AI review subsystem stays disabled unless this is exactly "true".
AI_ENABLED="false"
AI_MOCK_MODE="true"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
