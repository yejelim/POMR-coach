# Local desktop/default development.
DATABASE_URL="file:./prisma/dev.db"

# Web/Postgres mode uses the same variable name at runtime.
# Keep the real value in .env.web.local or deployment secrets.
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# Web alpha / Supabase Auth
# Keep real values in .env.local or deployment secrets only.
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
APP_URL="http://localhost:3000"
DATABASE_POOL_MAX="5"
# TLS to Supabase Postgres is verified by default. Set to "true" only for unusual
# setups that must skip certificate verification (not recommended).
# DATABASE_SSL_NO_VERIFY="false"
HEALTH_DEBUG="false"
# Health detail output additionally requires this secret in the x-health-token header.
HEALTH_DEBUG_TOKEN=""

# AI review subsystem. Disabled by default: the /api/ai/review route returns 503
# unless AI_ENABLED is exactly "true". Re-enabling still needs PHI/prompt-injection
# hardening before real use (see src/ai/flags.ts).
AI_ENABLED="false"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
AI_MOCK_MODE="false"
